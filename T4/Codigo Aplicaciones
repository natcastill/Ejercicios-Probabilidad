# ------------------------------------------------------------
#  1.1 DISTRIBUCIÓN BINOMIAL
# ------------------------------------------------------------

from scipy.stats import binom
import numpy as np
import matplotlib.pyplot as plt

# ── Ejercicio B-1 ────────────────────────────────────────────
# Examen de opción múltiple: n=10 preguntas, p=1/4 por azar
print("=" * 50)
print("EJERCICIO B-1 — Examen opción múltiple")
print("=" * 50)

n, p = 10, 0.25

p1 = binom.pmf(3, n, p)               # P(X = 3)
p2 = 1 - binom.cdf(7, n, p)           # P(X >= 8)
media = n * p
var   = n * p * (1 - p)

print(f"P(X=3)    = {p1:.6f}")
print(f"P(X>=8)   = {p2:.6f}")
print(f"E(X)      = {media}")
print(f"Var(X)    = {var}")

# ── Ejercicio B-2 ────────────────────────────────────────────
# Línea de producción: n=15 artículos, p=0.08 defectuosos
print("\n" + "=" * 50)
print("EJERCICIO B-2 — Línea de producción")
print("=" * 50)

n, p = 15, 0.08

p1 = binom.cdf(2, n, p)               # P(X <= 2)
p2 = binom.pmf(0, n, p)               # P(X = 0)
media = n * p                          # E(X) = 1.2 -> k=1
p3 = binom.pmf(1, n, p)               # P(X = 1)

print(f"P(X<=2)   = {p1:.6f}")
print(f"P(X=0)    = {p2:.6f}")
print(f"E(X)      = {media}")
print(f"P(X=1)    = {p3:.6f}")

# ── Aplicación Binomial ──────────────────────────────────────
# Control de calidad en chips: n=20, p=0.05, rechazo si X > 2
print("\n" + "=" * 50)
print("APLICACIÓN BINOMIAL — Control de calidad chips")
print("=" * 50)

n, p = 20, 0.05

p_aceptar  = binom.cdf(2, n, p)
p_rechazar = 1 - p_aceptar
print(f"P(aceptar)  = {p_aceptar:.6f}")
print(f"P(rechazar) = {p_rechazar:.6f}")

# Gráfica PMF
x      = np.arange(0, n + 1)
pmf    = binom.pmf(x, n, p)
colors = ['tomato' if xi > 2 else 'steelblue' for xi in x]

plt.figure(figsize=(9, 4))
plt.bar(x, pmf, color=colors, edgecolor='white', linewidth=0.6)
plt.axvline(2.5, color='red', linestyle='--', label='Umbral rechazo (X>2)')
plt.xlabel('Número de chips defectuosos (X)')
plt.ylabel('P(X = k)')
plt.title('PMF Binomial — Control de Calidad (n=20, p=0.05)')
plt.legend()
plt.tight_layout()
plt.savefig('binomial_aplicacion.png', dpi=150)
plt.show()


# ------------------------------------------------------------
#  1.2 DISTRIBUCIÓN DE POISSON
# ------------------------------------------------------------

from scipy.stats import poisson

# ── Ejercicio P-1 ────────────────────────────────────────────
# Central telefónica: lambda=3 llamadas/minuto
print("\n" + "=" * 50)
print("EJERCICIO P-1 — Central telefónica")
print("=" * 50)

lam = 3

p1 = poisson.pmf(5, lam)              # P(X = 5)
p2 = poisson.cdf(2, lam)              # P(X <= 2)
p3 = 1 - poisson.pmf(0, lam)          # P(X >= 1)

print(f"P(X=5)    = {p1:.6f}")
print(f"P(X<=2)   = {p2:.6f}")
print(f"P(X>=1)   = {p3:.6f}")

# ── Ejercicio P-2 ────────────────────────────────────────────
# Accidentes en autopista: lambda=2 accidentes/semana
print("\n" + "=" * 50)
print("EJERCICIO P-2 — Accidentes en autopista")
print("=" * 50)

lam = 2

p1 = poisson.pmf(4, lam)                              # P(X = 4)
p2 = poisson.cdf(3, lam) - poisson.cdf(0, lam)       # P(1 <= X <= 3)
p3 = poisson.pmf(0, lam)                              # P(X = 0)

print(f"P(X=4)       = {p1:.6f}")
print(f"P(1<=X<=3)   = {p2:.6f}")
print(f"P(X=0)       = {p3:.6f}")

# ── Aplicación Poisson ───────────────────────────────────────
# Servidor web: lambda=8 solicitudes/segundo, colapso si X > 12
print("\n" + "=" * 50)
print("APLICACIÓN POISSON — Servidor web")
print("=" * 50)

lam = 8

p_colapso = 1 - poisson.cdf(12, lam)
p_exacta  = poisson.pmf(8, lam)
print(f"P(colapso)  = {p_colapso:.6f}")
print(f"P(X=8)      = {p_exacta:.6f}")

# Gráfica PMF
x      = np.arange(0, 21)
pmf    = poisson.pmf(x, lam)
colors = ['tomato' if xi > 12 else 'mediumseagreen' for xi in x]

plt.figure(figsize=(9, 4))
plt.bar(x, pmf, color=colors, edgecolor='white')
plt.axvline(12.5, color='red', linestyle='--', label='Umbral colapso (X>12)')
plt.xlabel('Solicitudes por segundo (X)')
plt.ylabel('P(X = k)')
plt.title('PMF Poisson — Servidor Web (lam=8)')
plt.legend()
plt.tight_layout()
plt.savefig('poisson_aplicacion.png', dpi=150)
plt.show()


